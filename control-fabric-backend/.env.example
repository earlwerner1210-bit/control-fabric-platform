# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=control-fabric-backend
APP_VERSION=0.1.0
ENVIRONMENT=dev
DEBUG=true
LOG_LEVEL=DEBUG

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/control_fabric
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT / Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=local-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── Temporal ────────────────────────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=control-fabric-queue

# ── Inference ───────────────────────────────────────────────────────────────
# Providers: vllm | mlx | fake
INFERENCE_PROVIDER=fake
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=default
OPENAI_API_KEY=
MLX_ENABLED=false
MLX_MODEL_PATH=

# ── Embeddings ──────────────────────────────────────────────────────────────
# Providers: openai | local | fake
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ── Storage ─────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ── Observability ───────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
METRICS_ENABLED=false
