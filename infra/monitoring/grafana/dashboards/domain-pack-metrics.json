{
  "uid": "domain-pack-metrics",
  "title": "Domain Pack Metrics",
  "description": "Control Fabric Platform - Domain pack control objects, validation, leakage, and reconciliation",
  "tags": ["domain-packs", "control-fabric"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "domain",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "query": "label_values(control_objects_total, domain)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Control Objects by Domain",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(control_objects_total{domain=~\"$domain\"}[5m])) by (domain)",
          "legendFormat": "{{ domain }}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "title": "Validation Pass / Fail Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Pass Rate" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Fail Rate" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(validation_checks_total{domain=~\"$domain\", result=\"pass\"}[5m])) / sum(rate(validation_checks_total{domain=~\"$domain\"}[5m]))",
          "legendFormat": "Pass Rate"
        },
        {
          "refId": "B",
          "expr": "sum(rate(validation_checks_total{domain=~\"$domain\", result=\"fail\"}[5m])) / sum(rate(validation_checks_total{domain=~\"$domain\"}[5m]))",
          "legendFormat": "Fail Rate"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 3,
      "title": "Leakage Detection Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(leakage_detected_total{domain=~\"$domain\"}[5m])) by (domain, leakage_type)",
          "legendFormat": "{{ domain }} - {{ leakage_type }}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "mean"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 4,
      "title": "Reconciliation Success Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(reconciliation_total{domain=~\"$domain\", status=\"success\"}[5m])) by (domain) / sum(rate(reconciliation_total{domain=~\"$domain\"}[5m])) by (domain)",
          "legendFormat": "{{ domain }}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "min"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 5,
      "title": "Validation Checks by Domain (24h)",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(validation_checks_total{domain=~\"$domain\"}[24h])) by (domain)",
          "legendFormat": "{{ domain }}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 6,
      "title": "Leakage Amount by Domain (24h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 100000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(leakage_amount_dollars_total{domain=~\"$domain\"}[24h])) by (domain)",
          "legendFormat": "{{ domain }}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 7,
      "title": "Reconciliation Events (24h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(reconciliation_total{domain=~\"$domain\"}[24h])) by (domain)",
          "legendFormat": "{{ domain }}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 8,
      "title": "Validation Failure Breakdown by Rule",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(validation_checks_total{domain=~\"$domain\", result=\"fail\"}[5m])) by (rule_name, domain)",
          "legendFormat": "{{ domain }} / {{ rule_name }}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "mean"] },
        "tooltip": { "mode": "multi" }
      }
    }
  ]
}
